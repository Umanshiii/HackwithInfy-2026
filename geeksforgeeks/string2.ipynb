    "#1\n",
    "#Remove string duplicates\n",
    "\n",
    "class Solution:\n",
    "\tdef removeDuplicates(self, s):\n",
    "\t    # code here\n",
    "\t    seen=set()\n",
    "\t    output=''\n",
    "\t    for i in s:\n",
    "\t        if i not in seen:\n",
    "\t            output+=i\n",
    "\t            seen.add(i)\n",
    "\t            \n",
    "\t    return output"
   ]
  }
 ],
